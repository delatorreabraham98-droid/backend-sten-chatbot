PORT=3000
NODE_ENV=development

META_VERIFY_TOKEN=change_this_verify_token
META_ACCESS_TOKEN=replace_with_meta_access_token
META_PHONE_NUMBER_ID=replace_with_your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=replace_with_your_waba_id

# Transcripcion de audios (GROQ es gratis - https://console.groq.com)
GROQ_API_KEY=replace_with_groq_api_key

# Chat API (OpenAI o Groq - compatible API)
# OpenAI: OPENAI_API_KEY=sk-... + no base URL + gpt-4.1-mini
# Groq:   OPENAI_API_KEY=gsk_... + base URL + llama-3.3-70b-versatile (gratis)
OPENAI_API_KEY=replace_with_api_key
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile

BASE44_API_BASE_URL=https://your-base44-app.base44.app/api
BASE44_APP_ID=replace_with_your_base44_app_id
BASE44_API_KEY=replace_with_base44_api_key
BASE44_MESSAGE_HAS_CLIENT_ID=false

BOT_BUSINESS_NAME=La Torre LED Shop
BOT_TIMEZONE=America/Tijuana

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

TAVILY_API_KEY=replace_with_tavily_api_key

ADMIN_WHATSAPP_NUMBER=replace_with_admin_whatsapp_number

# Set to "true" to convert bot responses to audio using TTS
RESPOND_WITH_AUDIO=false
